<mujoco model="pendulum">
  <compiler angle="radian" coordinate="local" inertiafromgeom="true"/>
  <option gravity="0 -9.81 0" integrator="RK4" timestep="0.01"/>
  <worldbody>
    <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
    <geom type="plane" size="5 5 0.1" rgba=".9 .9 .9 1"/>
    <body name="pendulum_link" pos="0 1 0">
      <joint name="hinge_joint" type="hinge" axis="0 0 1" damping="0" frictionloss="0"/>
      <body name="rod" pos="0 0 0">
        <geom type="capsule" size="0.005" fromto="0 0 0 0.2485 0 0" mass="0" contype="0" conaffinity="0"/>
        <body name="bob" pos="0.2485 0 0">
          <geom type="sphere" size="0.05" mass="1.0"/>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>
